# Frontend build args (baked into the static build)
VITE_SUPABASE_URL=https://mwihidordzaecucczqoo.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=mwihidordzaecucczqoo

# Content server (backend) — set real values in Coolify, never commit them.
# ADMIN_USERNAME/PASSWORD: login for the "Contenido" tab (site text/prices editor).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-first-boot
JWT_SECRET=change-me-to-a-long-random-string

# Customer accounts (register/login/Google) — own auth system, independent of Supabase.
USER_JWT_SECRET=change-me-to-a-long-random-string

# Seeds the business-admin customer account (Solicitudes/Créditos/Sesiones grupales tabs
# in /admin) on every boot — same person who used to be granted the DB role in Supabase.
OWNER_EMAIL=
OWNER_PASSWORD=change-me-before-first-boot

# Google login — Client ID from Google Cloud Console (OAuth consent screen, "Web
# application" credential). No Client Secret needed: the backend verifies the token
# directly against Google, it doesn't do a server-side OAuth exchange. Used both as a
# frontend build arg (VITE_GOOGLE_CLIENT_ID) and read server-side (GOOGLE_CLIENT_ID),
# so one value here is enough. APPLE_SERVICES_ID is unused for now (no Apple button).
GOOGLE_CLIENT_ID=
APPLE_SERVICES_ID=
