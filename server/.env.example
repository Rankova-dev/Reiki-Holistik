PORT=3001
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-first-boot
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=https://your-domain.example
DB_PATH=./data/content.json
UPLOADS_DIR=./uploads
COURSE_MEDIA_DIR=./course-media
PAYMENT_PROOFS_DIR=./payment-proofs

# Customer accounts (register/login/Google) — own auth, independent of Supabase.
USER_JWT_SECRET=change-me-to-a-long-random-string

# Seeds the business-admin customer account (Solicitudes/Créditos/Sesiones grupales tabs).
OWNER_EMAIL=
OWNER_PASSWORD=change-me-before-first-boot

# Google login — Client ID only (no secret needed, see root .env.example for why).
GOOGLE_CLIENT_ID=
APPLE_SERVICES_ID=
